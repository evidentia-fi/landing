---
---

<section class="contact-page" id="contact">
  <img class="contact-bg" src="/bg-contact-us.webp" alt="" loading="eager" />
  <form class="contact-card" action="mailto:hello@evidentia.fi" method="post" enctype="text/plain">
    <div>
      <h1>Contact us</h1>
      <p>To contact us, please fill out and submit the feedback form.</p>
    </div>
    <label>
      <span>Name</span>
      <input name="name" type="text" autocomplete="name" placeholder="Name" />
    </label>
    <label>
      <span>Email</span>
      <input name="email" type="email" autocomplete="email" placeholder="Email" />
    </label>
    <label>
      <span>Message</span>
      <textarea name="message" rows="5" placeholder="Message"></textarea>
    </label>
    <button class="button button-primary" type="submit">Send</button>
  </form>
</section>
