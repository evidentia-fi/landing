---
import Logo from './Logo.astro';

const menuItems = [
  { title: 'Docs', href: '/docs.html' },
  { title: 'Issuer', href: 'https://ua.evidentia.fi/mint' },
  { title: 'Staking', href: 'https://ua.evidentia.fi/staking' },
];
---

<header class="site-header">
  <nav class="nav container" aria-label="Primary navigation">
    <Logo />
    <div class="nav-links">
      {
        menuItems.map(item => (
          <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined}>
            {item.title}
          </a>
        ))
      }
    </div>
    <div class="nav-actions">
      <a class="button button-secondary dashboard-link" href="https://ua.evidentia.fi/" target="_blank">
        Dashboard
        <span aria-hidden="true">↗</span>
      </a>
      <button class="icon-button" type="button" aria-label="Open menu" aria-expanded="false" data-menu-button>
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
  <div class="mobile-menu" data-mobile-menu>
    <div class="mobile-panel" role="dialog" aria-modal="true" aria-label="Navigation menu">
      <div class="mobile-panel-header">
        <Logo compact />
        <button class="icon-button close-button" type="button" aria-label="Close menu" data-menu-close>
          <span></span>
          <span></span>
        </button>
      </div>
      <div class="mobile-links">
        {
          menuItems.map(item => (
            <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined}>
              {item.title}
            </a>
          ))
        }
      </div>
      <a class="button button-secondary mobile-dashboard" href="https://ua.evidentia.fi/" target="_blank">
        Dashboard
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</header>
